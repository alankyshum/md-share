{
  "name": "@alankyshum/markdown-renderer",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "build": "tsup"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./client/maps": {
      "import": "./dist/client/maps.js",
      "types": "./dist/client/maps.d.ts"
    },
    "./client/charts": {
      "import": "./dist/client/charts.js",
      "types": "./dist/client/charts.d.ts"
    },
    "./client/gantt": {
      "import": "./dist/client/gantt.js",
      "types": "./dist/client/gantt.d.ts"
    },
    "./client/tables": {
      "import": "./dist/client/tables.js",
      "types": "./dist/client/tables.d.ts"
    },
    "./client/markmaps": {
      "import": "./dist/client/markmaps.js",
      "types": "./dist/client/markmaps.d.ts"
    },
    "./client/mermaid": {
      "import": "./dist/client/mermaid-init.js",
      "types": "./dist/client/mermaid-init.d.ts"
    },
    "./styles/renderer.css": "./dist/styles/renderer.css"
  },
  "peerDependencies": {
    "marked": "^15.0.0",
    "mermaid": "^11.0.0",
    "markmap-lib": "*",
    "markmap-view": "*",
    "highlight.js": "^11.0.0",
    "maplibre-gl": "^4.0.0",
    "js-yaml": "^4.0.0",
    "chart.js": "*",
    "chartjs-plugin-annotation": "*",
    "frappe-gantt": "*",
    "tabulator-tables": "*"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.0.2"
  }
}
